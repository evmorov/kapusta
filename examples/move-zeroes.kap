(fn move-zeroes [nums]
  (var write 0)
  (for [read 0 (- (length nums) 1)]
    (when (not= (. nums read) 0)
      (tset nums write (. nums read))
      (set write (+ write 1))))
  (for [i write (- (length nums) 1)]
    (tset nums i 0))
  nums)

(print (move-zeroes [0 1 0 3 12]))
(print (move-zeroes [0]))
(print (move-zeroes [1 2 3]))
