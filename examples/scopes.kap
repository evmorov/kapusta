(class ScopeCounter)

(set (cvar total) 0)

(fn add! [n]
  (set (cvar total) (+ (cvar total) n))
  (set (gvar last-total) (cvar total))
  (cvar total))

(fn self.total []
  (cvar total))

(end)

(let [a (ScopeCounter.new)
      b (ScopeCounter.new)]
  (print (a.add! 5))
  (print (b.add! 4))
  (print (ScopeCounter.total))
  (print (gvar last-total)))
