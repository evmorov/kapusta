(fn require-score [s]
  (if (= s "oops")
      (raise (ArgumentError.new "not a number"))
      (: s :to-i)))

(fn parse-score [s]
  (try (require-score s)
    (catch ArgumentError e
      (.. "bad: " s))
    (finally
      (print (.. "seen: " s)))))

(each [_ s (ipairs ["12" "oops"])]
  (print (parse-score s)))
