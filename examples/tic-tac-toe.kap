(fn winner [board]
  (case board
    [["X" "X" "X"] _ _] "X"
    [_ ["O" "O" "O"] _] "O"
    [["X" _ _] [_ "X" _] [_ _ "X"]] "X"
    [["O" _ _] ["O" _ _] ["O" _ _]] "O"
    _ "draw"))

(each [_ board (ipairs [[["X" "X" "X"] ["O" "" ""] ["" "O" ""]]
                        [["O" "X" "X"] ["O" "" "X"] ["O" "" ""]]
                        [["X" "O" ""] ["" "X" "O"] ["" "" "X"]]
                        [["X" "O" "X"] ["O" "X" "O"] ["O" "X" "O"]]])]
  (print (winner board)))
