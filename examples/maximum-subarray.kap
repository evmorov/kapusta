(fn max-subarray [nums]
  (var best (. nums 0))
  (var curr (. nums 0))
  (for [i 1 (- (length nums) 1)]
    (let [n (. nums i)]
      (set curr (if (> (+ curr n) n) (+ curr n) n))
      (when (> curr best) (set best curr))))
  best)

(print (max-subarray [-2 1 -3 4 -1 2 1 -5 4]))
(print (max-subarray [1]))
(print (max-subarray [5 4 -1 7 8]))
